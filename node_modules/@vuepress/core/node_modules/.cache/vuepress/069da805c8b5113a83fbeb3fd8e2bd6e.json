 undefined) {\r\n      this.opacity = bodyBgImgOpacity\r\n    }\r\n\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang='stylus'>\r\n.body-bg\r\n  position fixed\r\n  left 0\r\n  top 0\r\n  z-index -999999\r\n  height 100vh\r\n  width 100vw\r\n  transition background 0.5s\r\n</style>\r\n"]}]}