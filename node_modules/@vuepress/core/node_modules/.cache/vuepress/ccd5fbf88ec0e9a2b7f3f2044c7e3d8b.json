A,EAAA,OAhBA,qBAgBA;AACA,SAAA,KAAA,GAAA,KAAA,UAAA,CAAA,MAAA;AACA,GAlBA;AAmBA,EAAA,WAnBA,yBAmBA;AACA,SAAA,UAAA,GAAA,MAAA,CAAA,UAAA,GAAA,yBAAA,GAAA,IAAA,GAAA,KAAA,CADA,CACA;AACA,GArBA;AAsBA,EAAA,OAtBA,qBAsBA;AAAA;;AACA,QAAA,KAAA,MAAA,CAAA,KAAA,CAAA,CAAA,EAAA;AACA,WAAA,WAAA,GAAA,MAAA,CAAA,KAAA,MAAA,CAAA,KAAA,CAAA,CAAA,CAAA;AACA;;AAEA,QAAA,KAAA,UAAA,KAAA,CAAA,KAAA,MAAA,CAAA,KAAA,CAAA,CAAA,IAAA,KAAA,MAAA,CAAA,KAAA,CAAA,CAAA,IAAA,CAAA,CAAA,EAAA;AACA,WAAA,IAAA;AACA;;AAEA,IAAA,MAAA,CAAA,gBAAA,CAAA,QAAA,EAAA,YAAA;AACA,MAAA,KAAA,CAAA,UAAA,GAAA,MAAA,CAAA,UAAA,GAAA,yBAAA,GAAA,IAAA,GAAA,KAAA;;AACA,UAAA,KAAA,CAAA,UAAA,IAAA,CAAA,KAAA,CAAA,KAAA,IAAA,CAAA,KAAA,CAAA,IAAA,EAAA;AACA,QAAA,KAAA,CAAA,IAAA;AACA,QAAA,UAAA,CAAA,YAAA;AACA,UAAA,KAAA,CAAA,IAAA;AACA,SAFA,EAEA,EAFA,CAAA;AAGA;AACA,KARA;AAUA,GAzCA;AA0CA,EAAA,aA1CA,2BA0CA;AACA,IAAA,YAAA,CAAA,KAAA,SAAA,CAAA;AACA,SAAA,KAAA,IAAA,KAAA,KAAA,CAAA,OAAA,EAAA;AACA,GA7CA;AA8CA,EAAA,KAAA,EAAA;AACA,oBADA,0BACA;AAAA;;AACA,UAAA,CAAA,KAAA,MAAA,CAAA,KAAA,CAAA,CAAA,EAAA;AACA,aAAA,WAAA,GAAA,CAAA;AACA,OAFA,MAEA;AACA,aAAA,WAAA,GAAA,MAAA,CAAA,KAAA,MAAA,CAAA,KAAA,CAAA,CAAA,CAAA;AACA;;AAEA,UAAA,KAAA,WAAA,KAAA,CAAA,IAAA,KAAA,UAAA,EAAA;AACA,QAAA,UAAA,CAAA,YAAA;AACA,UAAA,MAAA,CAAA,KAAA,IAAA,MAAA,CAAA,KAAA,CAAA,OAAA,EAAA;;AACA,UAAA,MAAA,CAAA,IAAA;AACA,SAHA,EAGA,CAHA,CAAA;AAIA;AACA;AAdA,GA9CA;AA8DA,EAAA,OAAA,EAAA;AACA,IAAA,IADA,kBACA;AAAA;;AACA,MAAA,YAAA,CAAA,KAAA,SAAA,CAAA;AACA,WAAA,KAAA,GAAA,IAAA,OAAA,CAAA,KAAA,KAAA,CAAA,KAAA,EAAA;AACA,QAAA,OAAA,EAAA,IADA;AACA;AACA,QAAA,OAAA,EAAA,KAFA;AAEA;AACA,QAAA,KAAA,EAAA;AACA,UAAA,IAAA,EAAA,IADA;AAEA,UAAA,SAAA,EAAA;AAFA,SAHA;AAOA,QAAA,aAAA,EAAA,IAPA;AAOA;AACA,QAAA,QAAA,EAAA,KARA;AASA,QAAA,MAAA,EAAA,KATA;AASA;AACA,QAAA,eAAA,EAAA,KAVA;AAUA;AACA,QAAA,SAAA,EAAA,CAXA;AAYA,QAAA,cAAA,EAAA;AAZA,OAAA,CAAA,CAFA,CAiBA;;AACA,WAAA,KAAA,CAAA,EAAA,CAAA,mBAAA,EAAA,YAAA;AACA,QAAA,YAAA,CAAA,MAAA,CAAA,SAAA,CAAA;AACA,OAFA,EAlBA,CAqBA;;AACA,WAAA,KAAA,CAAA,EAAA,CAAA,WAAA,EAAA,YAAA;AACA,QAAA,MAAA,CAAA,UAAA;AACA,OAFA;AAGA,WAAA,KAAA,CAAA,EAAA,CAAA,iBAAA,EAAA,UAAA,IAAA,EAAA;AACA,QAAA,MAAA,CAAA,gBAAA,GAAA,IAAA,CAAA,KAAA;AACA,OAFA;AAGA,WAAA,UAAA;AACA,KA9BA;AA+BA,IAAA,UA/BA,wBA+BA;AAAA;;AACA,MAAA,YAAA,CAAA,KAAA,SAAA,CAAA;AACA,WAAA,SAAA,GAAA,UAAA,CAAA,YAAA;AACA,QAAA,MAAA,CAAA,KAAA,CAAA,IAAA;AACA,OAFA,EAEA,IAFA,CAAA;AAGA,KApCA;AAqCA,IAAA,gBArCA,4BAqCA,CArCA,EAqCA;AAAA;AACA,WAAA,WAAA,GAAA,CAAA;AACA,KAvCA;AAwCA,IAAA,YAxCA,0BAwCA;AACA,aAAA,MAAA,CAAA,WAAA,IACA,QAAA,CAAA,eAAA,CAAA,SADA,IAEA,QAAA,CAAA,IAAA,CAAA,SAFA;AAGA;AA5CA,GA9DA;AA6GA,EAAA,QAAA,EAAA;AACA,IAAA,UADA,wBACA;AAAA;AACA,aAAA,KAAA,MAAA,CAAA,KAAA,CAAA,CAAA,IACA,KAAA,MAAA,CAAA,KAAA,CAAA,CAAA,IAAA,CADA,KAEA,CAAA,KAAA,QAAA,CAAA,QAAA,IAAA,KAAA,QAAA,CAAA,QAAA,KAAA,UAFA,IAGA,KAHA,GAGA,IAHA;AAIA,KANA;AAOA,IAAA,aAPA,2BAOA;AACA,UAAA,QAAA,GAAA,KAAA,QAAA,CAAA,QAAA;;AACA,UAAA,CAAA,QAAA,IAAA,QAAA,KAAA,MAAA,EAAA;AAAA;AACA,YAAA,KAAA,YAAA,CAAA,SAAA,EAAA;AAAA;AACA,iBAAA,EAAA;AACA,SAFA,MAEA;AAAA;AACA,iBAAA,+SAAA;AACA;AACA,OANA,MAMA,IAAA,QAAA,KAAA,MAAA,EAAA;AAAA;AACA,YAAA,KAAA,YAAA,CAAA,SAAA,EAAA;AACA,iBAAA,EAAA;AACA,SAFA,MAEA;AACA,iBAAA,mDAAA;AACA;AACA,OANA,MAMA,IAAA,QAAA,CAAA,OAAA,CAAA,YAAA,IAAA,CAAA,CAAA,EAAA;AAAA;AACA,eAAA,QAAA;AACA,OAFA,MAEA,IAAA,QAAA,CAAA,OAAA,CAAA,GAAA,IAAA,CAAA,CAAA,EAAA;AAAA;AACA,yCAAA,KAAA,SAAA,CAAA,QAAA,CAAA;AACA;AAEA,KA3BA;AA4BA,IAAA,QA5BA,sBA4BA;AACA,+BACA,KAAA,KAAA,CAAA,WADA;AAGA,KAhCA;AAiCA,IAAA,UAjCA,wBAiCA;AACA,aAAA;AACA,QAAA,IAAA,EAAA,KAAA,QAAA,CAAA,UADA;AAEA,QAAA,IAAA,EAAA,KAAA,QAAA,CAAA;AAFA,OAAA;AAIA;AAtCA;AA7GA,CAAA","sourcesContent":["<template>\r\n  <div class=\"home-wrapper\">\r\n    <!-- bannerеЭЧ s -->\r\n    <div\r\n      class=\"banner\"\r\n      :class=\"{'hide-banner': !showBanner}\"\r\n      :style=\"bannerBgStyle\"\r\n    >\r\n      <div\r\n        class=\"banner-conent\"\r\n        :style=\"!homeData.features && !homeData.heroImage && `padding-top: 7rem`\"\r\n      >\r\n        <header class=\"hero\">\r\n          <img\r\n            v-if=\"homeData.heroImage\"\r\n            :src=\"$withBase(homeData.heroImage)\"\r\n            :alt=\"homeData.heroAlt\"\r\n          />\r\n          <h1\r\n            v-if=\"homeData.heroText\"\r\n            id=\"main-title\"\r\n          >{{ homeData.heroText }}</h1>\r\n          <p\r\n            v-if=\"homeData.tagline\"\r\n            class=\"description\"\r\n          >{{ homeData.tagline }}</p>\r\n          <p\r\n            class=\"action\"\r\n            v-if=\"homeData.actionText && homeData.actionLink\"\r\n          >\r\n            <NavLink\r\n              class=\"action-button\"\r\n              :item=\"actionLink\"\r\n            />\r\n          </p>\r\n        </header>\r\n\r\n        <!-- PCзЂѓfeaturesеЭЧ s -->\r\n        <div\r\n          class=\"features\"\r\n          v-if=\"homeData.features && homeData.features.length && !isMQMobile\"\r\n        >\r\n          <div\r\n            class=\"feature\"\r\n            v-for=\"(feature, index) in homeData.features\"\r\n            :key=\"index\"\r\n          >\r\n            <router-link\r\n              v-if=\"feature.link\"\r\n              :to=\"feature.link\"\r\n            >\r\n              <img\r\n                class=\"feature-img\"\r\n                v-if=\"feature.imgUrl\"\r\n                :src=\"$withBase(feature.imgUrl)\"\r\n                :alt=\"feature.title\"\r\n              />\r\n              <h2>{{ feature.title }}</h2>\r\n              <p>{{ feature.details }}</p>\r\n            </router-link>\r\n            <a\r\n              v-else\r\n              href=\"javascript:;\"\r\n            >\r\n              <img\r\n                class=\"feature-img\"\r\n                v-if=\"feature.imgUrl\"\r\n                :src=\"$withBase(feature.imgUrl)\"\r\n                :alt=\"feature.title\"\r\n              />\r\n              <h2>{{ feature.title }}</h2>\r\n              <p>{{ feature.details }}</p>\r\n            </a>\r\n          </div>\r\n        </div>\r\n        <!-- PCзЂѓfeaturesеЭЧ e -->\r\n      </div>\r\n\r\n      <!-- зІїеК®зЂѓfeaturesеЭЧ s -->\r\n      <!-- isMQMobileжФЊеИ∞v-ifдЄКзЇњеРОдЉЪжК•йФЩ -->\r\n      <div\r\n        class=\"slide-banner\"\r\n        v-if=\"homeData.features && homeData.features.length\"\r\n        v-show=\"isMQMobile\"\r\n      >\r\n        <div class=\"banner-wrapper\">\r\n          <div\r\n            class=\"slide-banner-scroll\"\r\n            ref=\"slide\"\r\n          >\r\n            <div class=\"slide-banner-wrapper\">\r\n              <div\r\n                class=\"slide-item\"\r\n                v-for=\"(feature, index) in homeData.features\"\r\n                :key=\"index\"\r\n              >\r\n                <router-link\r\n                  v-if=\"feature.link\"\r\n                  :to=\"feature.link\"\r\n                >\r\n                  <img\r\n                    class=\"feature-img\"\r\n                    v-if=\"feature.imgUrl\"\r\n                    :src=\"$withBase(feature.imgUrl)\"\r\n                    :alt=\"feature.title\"\r\n                  />\r\n                  <h2>{{ feature.title }}</h2>\r\n                  <p>{{ feature.details }}</p>\r\n                </router-link>\r\n                <a\r\n                  v-else\r\n                  href=\"javascript:;\"\r\n                >\r\n                  <img\r\n                    class=\"feature-img\"\r\n                    v-if=\"feature.imgUrl\"\r\n                    :src=\"$withBase(feature.imgUrl)\"\r\n                    :alt=\"feature.title\"\r\n                  />\r\n                  <h2>{{ feature.title }}</h2>\r\n                  <p>{{ feature.details }}</p>\r\n                </a>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"docs-wrapper\">\r\n            <span\r\n              class=\"doc\"\r\n              v-for=\"(item, index) in homeData.features.length\"\r\n              :key=\"index\"\r\n              :class=\"{'active': currentPageIndex === index}\"\r\n            ></span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <!-- зІїеК®зЂѓfeaturesеЭЧ e -->\r\n    </div>\r\n    <!-- bannerеЭЧ e -->\r\n\r\n    <MainLayout>\r\n      <template #mainLeft>\r\n        <!-- зЃАзЇ¶зЙИжЦЗзЂ†еИЧи°® -->\r\n        <UpdateArticle\r\n          class=\"card-box\"\r\n          v-if=\"homeData.postList === 'simple'\"\r\n          :length=\"homeData.simplePostListLength || 10\"\r\n        />\r\n\r\n        <!-- иѓ¶жГЕзЙИжЦЗзЂ†еИЧи°® -->\r\n        <template v-else-if=\"!homeData.postList || homeData.postList === 'detailed'\">\r\n          <PostList\r\n            :currentPage=\"currentPage\"\r\n            :perPage=\"perPage\"\r\n          />\r\n          <Pagination\r\n            :total=\"total\"\r\n            :perPage=\"perPage\"\r\n            :currentPage=\"currentPage\"\r\n            @getCurrentPage=\"handlePagination\"\r\n            v-show=\"Math.ceil(total / perPage) > 1\"\r\n          />\r\n        </template>\r\n\r\n        <Content class=\"theme-vdoing-content custom card-box\" />\r\n      </template>\r\n\r\n      <template #mainRight>\r\n        <BloggerBar v-if=\"$themeConfig.blogger\" />\r\n        <CategoriesBar\r\n          v-if=\"$themeConfig.category !== false && $categoriesAndTags.categories.length\"\r\n          :categoriesData=\"$categoriesAndTags.categories\"\r\n          :length=\"10\"\r\n        />\r\n        <TagsBar\r\n          v-if=\"$themeConfig.tag !== false && $categoriesAndTags.tags.length\"\r\n          :tagsData=\"$categoriesAndTags.tags\"\r\n          :length=\"30\"\r\n        />\r\n      </template>\r\n    </MainLayout>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport NavLink from \"@theme/components/NavLink\";\r\nimport BScroll from \"@better-scroll/core\"\r\nimport Slide from \"@better-scroll/slide\"\r\nimport MainLayout from '@theme/components/MainLayout'\r\nimport PostList from '@theme/components/PostList'\r\nimport UpdateArticle from '@theme/components/UpdateArticle'\r\nimport Pagination from '@theme/components/Pagination'\r\nimport BloggerBar from '@theme/components/BloggerBar'\r\nimport CategoriesBar from '@theme/components/CategoriesBar'\r\nimport TagsBar from '@theme/components/TagsBar'\r\n\r\nconst MOBILE_DESKTOP_BREAKPOINT = 720 // refer to config.styl\r\n\r\nBScroll.use(Slide)\r\n\r\nexport default {\r\n  data () {\r\n    return {\r\n      isMQMobile: false,\r\n\r\n      slide: null,\r\n      currentPageIndex: 0,\r\n      playTimer: 0,\r\n      mark: 0,\r\n\r\n      total: 0, // жАїйХњ\r\n      perPage: 10, // жѓПй°µйХњ\r\n      currentPage: 1// ељУеЙНй°µ\r\n    }\r\n  },\r\n  components: { NavLink, MainLayout, PostList, UpdateArticle, BloggerBar, CategoriesBar, TagsBar, Pagination },\r\n  created () {\r\n    this.total = this.$sortPosts.length\r\n  },\r\n  beforeMount () {\r\n    this.isMQMobile = window.innerWidth < MOBILE_DESKTOP_BREAKPOINT ? true : false; // vupressеЬ®жЙУеМЕжЧґдЄНиГљеЬ®beforeCreate(),created()иЃњйЧЃжµПиІИеЩ®apiпЉИе¶ВwindowпЉЙ\r\n  },\r\n  mounted () {\r\n    if (this.$route.query.p) {\r\n      this.currentPage = Number(this.$route.query.p)\r\n    }\r\n\r\n    if (this.isMQMobile && (!this.$route.query.p || this.$route.query.p == 1)) {\r\n      this.init()\r\n    }\r\n\r\n    window.addEventListener('resize', () => {\r\n      this.isMQMobile = window.innerWidth < MOBILE_DESKTOP_BREAKPOINT ? true : false;\r\n      if (this.isMQMobile && !this.slide && !this.mark) {\r\n        this.mark++\r\n        setTimeout(() => {\r\n          this.init()\r\n        }, 60)\r\n      }\r\n    })\r\n\r\n  },\r\n  beforeDestroy () {\r\n    clearTimeout(this.playTimer)\r\n    this.slide && this.slide.destroy()\r\n  },\r\n  watch: {\r\n    '$route.query.p' () {\r\n      if (!this.$route.query.p) {\r\n        this.currentPage = 1\r\n      } else {\r\n        this.currentPage = Number(this.$route.query.p)\r\n      }\r\n\r\n      if (this.currentPage === 1 && this.isMQMobile) {\r\n        setTimeout(() => {\r\n          this.slide && this.slide.destroy()\r\n          this.init()\r\n        }, 0)\r\n      }\r\n    }\r\n  },\r\n  methods: {\r\n    init () {\r\n      clearTimeout(this.playTimer)\r\n      this.slide = new BScroll(this.$refs.slide, {\r\n        scrollX: true, // xиљіжїЪеК®\r\n        scrollY: false, // yиљіжїЪеК®\r\n        slide: {\r\n          loop: true,\r\n          threshold: 100\r\n        },\r\n        useTransition: true, // дљњзФ®css3 transitionеК®зФї\r\n        momentum: false,\r\n        bounce: false, // еЫЮеЉє\r\n        stopPropagation: false, // жШѓеР¶йШїж≠ҐдЇЛдїґеЖТж≥°\r\n        probeType: 2,\r\n        preventDefault: false\r\n      })\r\n\r\n      // user touches the slide area\r\n      this.slide.on('beforeScrollStart', () => {\r\n        clearTimeout(this.playTimer)\r\n      })\r\n      // user touched the slide done\r\n      this.slide.on('scrollEnd', () => {\r\n        this.autoGoNext()\r\n      })\r\n      this.slide.on('slideWillChange', (page) => {\r\n        this.currentPageIndex = page.pageX\r\n      })\r\n      this.autoGoNext()\r\n    },\r\n    autoGoNext () {\r\n      clearTimeout(this.playTimer)\r\n      this.playTimer = setTimeout(() => {\r\n        this.slide.next()\r\n      }, 4000)\r\n    },\r\n    handlePagination (i) { // еИЖй°µ\r\n      this.currentPage = i\r\n    },\r\n    getScrollTop () {\r\n      return window.pageYOffset\r\n        || document.documentElement.scrollTop\r\n        || document.body.scrollTop\r\n    },\r\n  },\r\n\r\n  computed: {\r\n    showBanner () { // ељУеИЖй°µдЄНеЬ®зђђдЄАй°µжЧґйЪРиЧПbannerж†П\r\n      return this.$route.query.p\r\n        && this.$route.query.p != 1\r\n        && (!this.homeData.postList || this.homeData.postList === 'detailed')\r\n        ? false : true\r\n    },\r\n    bannerBgStyle () {\r\n      let bannerBg = this.homeData.bannerBg\r\n      if (!bannerBg || bannerBg === 'auto') { // йїШиЃ§\r\n        if (this.$themeConfig.bodyBgImg) { // ељУжЬЙbodyBgImgжЧґпЉМдЄНжШЊз§ЇиГМжЩѓ\r\n          return ''\r\n        } else { // зљСж†ЉзЇєиГМжЩѓ\r\n          return 'background: rgb(40,40,45) url(data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAACMAAAAjCAYAAAAe2bNZAAAAAXNSR0IArs4c6QAAAARnQU1BAACxjwv8YQUAAAAJcEhZcwAADsMAAA7DAcdvqGQAAABOSURBVFhH7c6xCQAgDAVRR9A6E4hLu4uLiWJ7tSnuQcIvr2TRYsw3/zOGGEOMIcYQY4gxxBhiDDGGGEOMIcYQY4gxxBhiDLkx52W4Gn1tuslCtHJvL54AAAAASUVORK5CYII=)'\r\n        }\r\n      } else if (bannerBg === 'none') { // жЧ†иГМжЩѓ\r\n        if (this.$themeConfig.bodyBgImg) {\r\n          return ''\r\n        } else {\r\n          return 'background: var(--mainBg);color: var(--textColor)'\r\n        }\r\n      } else if (bannerBg.indexOf('background') > -1) { // иЗ™еЃЪдєЙиГМжЩѓж†ЈеЉП\r\n        return bannerBg\r\n      } else if (bannerBg.indexOf('.') > -1) { // е§ІеЫЊ\r\n        return `background: url(${this.$withBase(bannerBg)}) center center / cover no-repeat`\r\n      }\r\n\r\n    },\r\n    homeData () {\r\n      return {\r\n        ...this.$page.frontmatter\r\n      }\r\n    },\r\n    actionLink () {\r\n      return {\r\n        link: this.homeData.actionLink,\r\n        text: this.homeData.actionText\r\n      };\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style lang=\"stylus\" scoped>\r\n.home-wrapper\r\n  .banner\r\n    width 100%\r\n    min-height 450px\r\n    margin-top $navbarHeight\r\n    color $bannerTextColor\r\n    position relative\r\n    overflow hidden\r\n    .banner-conent\r\n      max-width $homePageWidth\r\n      margin 0px auto\r\n      position relative\r\n      z-index 1\r\n      overflow hidden\r\n      .hero\r\n        text-align center\r\n        margin-top 3rem\r\n        img\r\n          max-width 100%\r\n          max-height 240px\r\n          display block\r\n          margin 2rem auto 1.5rem\r\n        h1\r\n          margin 0\r\n          font-size 3.2rem\r\n        .description, .action\r\n          margin 1.5rem auto\r\n        .description\r\n          max-width 40rem\r\n          font-size 1.1rem\r\n          line-height 1.3\r\n          opacity 0.9\r\n        .action-button\r\n          display inline-block\r\n